{
  "expo": {
    "name": "ReciTalk",
    "slug": "recitalk",
    "version": "1.0.0",

    "orientation": "portrait",

    "icon": "./assets/icon.png",

    "userInterfaceStyle": "light",

    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },

    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "영수증 사진 업로드를 위해 갤러리 접근 권한이 필요합니다.",
          "cameraPermission": "영수증 촬영을 위해 카메라 권한이 필요합니다."
        }
      ]
    ],

    "android": {
      "package": "com.junsang.recitalk",

      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#ffffff"
      }
    }
  }
}